<%- include('partials/head', { title: 'API Keys · dapuranmu' }) %>
<div class="flex">
  <%- include('partials/sidebar') %>
  <main class="flex-1 p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-semibold">API Keys</h1>
        <p class="text-sm text-slate-500">Keys your users send as <code>Authorization: Bearer ...</code> when calling <code>/v1</code>.</p>
      </div>
      <button onclick="createKey()" class="bg-brand-500 hover:bg-brand-600 text-white text-sm px-4 py-2 rounded-md">+ New key</button>
    </div>

    <div id="newKeyAlert" class="hidden mb-4 p-4 rounded-xl border border-amber-300 bg-amber-50">
      <div class="text-sm font-medium text-amber-900 mb-1">Save this key now. It will not be shown again.</div>
      <div class="text-xs text-slate-500 mb-3">The key is copied automatically when your browser allows clipboard access.</div>
      <div class="flex items-center gap-2">
        <code id="newKeyVal" class="font-mono text-xs bg-white border border-amber-200 rounded px-3 py-2 flex-1 overflow-x-auto"></code>
        <button id="copyNewKeyBtn" onclick="copyKey()" class="text-xs px-3 py-2 rounded-md bg-amber-500 text-white hover:bg-amber-600">Copy</button>
      </div>
      <button onclick="location.reload()" class="mt-3 text-xs text-brand-600 hover:underline">Done, refresh list</button>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
      <div class="px-4 py-3 border-b border-slate-200 text-xs text-slate-500">
        Browser-local copies appear only on this machine and only for keys created here after this change.
      </div>
      <table class="w-full text-sm">
        <thead class="text-xs text-slate-500 bg-slate-50">
          <tr>
            <th class="text-left font-medium px-4 py-2">Name</th>
            <th class="text-left font-medium px-4 py-2">Prefix</th>
            <th class="text-left font-medium px-4 py-2">Status</th>
            <th class="text-left font-medium px-4 py-2">Last used</th>
            <th class="text-left font-medium px-4 py-2">Created</th>
            <th class="text-right font-medium px-4 py-2">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!rows.length) { %>
            <tr><td colspan="6" class="px-4 py-10 text-center text-slate-400">No API keys yet.</td></tr>
          <% } %>
          <% rows.forEach(r => { %>
            <tr class="border-t border-slate-100">
              <td class="px-4 py-2 font-medium"><%= r.name %></td>
              <td class="px-4 py-2 font-mono text-xs text-slate-500"><%= r.key_prefix %>...</td>
              <td class="px-4 py-2">
                <% if (r.revoked_at) { %>
                  <span class="text-rose-500 text-xs">revoked</span>
                <% } else if (r.enabled) { %>
                  <span class="text-emerald-600 text-xs">active</span>
                <% } else { %>
                  <span class="text-slate-400 text-xs">disabled</span>
                <% } %>
              </td>
              <td class="px-4 py-2 text-xs text-slate-500"><%= formatDate(r.last_used_at) %></td>
              <td class="px-4 py-2 text-xs text-slate-500"><%= formatDate(r.created_at) %></td>
              <td class="px-4 py-2 text-right">
                <button
                  class="copy-saved-key-btn hidden text-brand-600 text-xs hover:underline mr-2"
                  data-key-prefix="<%= r.key_prefix %>">
                  Copy
                </button>
                <% if (!r.revoked_at) { %>
                  <button onclick="revokeKey(<%= r.id %>, '<%= r.name %>')" class="text-amber-600 text-xs hover:underline">Revoke</button>
                <% } %>
                <button onclick="deleteKey(<%= r.id %>, '<%= r.name %>')" class="text-rose-600 text-xs hover:underline ml-2">Delete</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<script src="/js/api-keys.js"></script>
</body>
</html>
