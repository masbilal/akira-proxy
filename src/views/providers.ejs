<%- include('partials/head', { title: 'Providers · Akira Proxy' }) %>
<div class="flex">
  <%- include('partials/sidebar') %>
  <main class="flex-1 p-8">
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-2xl font-semibold">Providers</h1>
        <p class="text-sm text-slate-500 mt-1">Upstream adapters, account pools, and model capacity.</p>
      </div>
      <button onclick="openProviderModal()" class="bg-brand-500 hover:bg-brand-600 text-white text-sm px-4 py-2 rounded-md">+ Add provider</button>
    </div>

    <% if (!rows.length) { %>
      <div class="bg-white rounded-xl border border-slate-200 p-10 text-center">
        <div class="text-lg font-medium">No providers yet</div>
        <p class="text-sm text-slate-500 mt-2">Add one to start routing traffic.</p>
      </div>
    <% } %>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-5">
      <% rows.forEach((r) => {
           const s = r.accountSummary.stats;
           const statusTone = !r.enabled ? 'pool-muted' : s.exhausted > 0 ? 'pool-warn' : 'pool-ok';
      %>
        <article class="provider-pool-card bg-white rounded-xl border border-slate-200 p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex items-start gap-3">
              <%- include('partials/provider-icon', { type: r.type, size: 24 }) %>
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <h2 class="text-lg font-semibold truncate"><%= r.name %></h2>
                  <span class="tier-chip tier-enterprise"><%= r.type %></span>
                </div>
                <p class="text-xs text-slate-500 font-mono truncate mt-1"><%= r.base_url %></p>
              </div>
            </div>
            <span class="pool-status <%= statusTone %>"><%= r.enabled ? 'enabled' : 'disabled' %></span>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-5">
            <div class="pool-metric"><span>Accounts</span><strong><%= s.total %></strong></div>
            <div class="pool-metric"><span>Active</span><strong class="text-emerald-600"><%= s.active %></strong></div>
            <div class="pool-metric"><span>Models</span><strong><%= r.enabled_model_count %>/<%= r.model_count %></strong></div>
            <div class="pool-metric"><span>Exhausted</span><strong class="text-rose-600"><%= s.exhausted %></strong></div>
          </div>

          <div class="mt-5">
            <div class="flex items-center justify-between text-xs text-slate-500 mb-2">
              <span>Account credits</span>
              <span><%= s.creditsLimit ? `${s.creditsCurrent} / ${s.creditsLimit}` : 'unknown' %></span>
            </div>
            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
              <div class="account-credit-bar" style="width:<%= r.accountSummary.creditPct %>%"></div>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mt-5">
            <% [
                 ['free', s.free],
                 ['plus', s.plus],
                 ['pro', s.pro],
                 ['team', s.team],
                 ['business', s.business],
                 ['edu', s.edu],
                 ['power', s.power],
                 ['enterprise', s.enterprise],
                 ['unknown', s.unknown],
               ].forEach(([tier, count]) => { %>
              <% if (count > 0) { %>
                <span class="tier-chip tier-<%= tier %>"><%= tier %>: <%= count %></span>
              <% } %>
            <% }) %>
          </div>

          <div class="flex items-center justify-between gap-3 mt-5 border-t border-slate-200 pt-4">
            <div class="text-xs text-slate-500">Updated <%= formatDate(r.updated_at) %></div>
            <div class="flex flex-wrap justify-end gap-3">
              <a href="/accounts/<%= r.id %>" class="text-brand-600 text-xs hover:underline">Accounts</a>
              <% if (r.type === 'kiro') { %>
                <button onclick="warmupProvider(<%= r.id %>)" class="text-amber-600 text-xs hover:underline">Warmup</button>
                <button onclick="refreshSubscription(<%= r.id %>)" class="text-indigo-600 text-xs hover:underline">Refresh plan</button>
              <% } %>
              <button onclick='editProvider(<%- JSON.stringify(r) %>)' class="text-brand-600 text-xs hover:underline">Edit</button>
              <button onclick="deleteProvider(<%= r.id %>, '<%= r.name %>')" class="text-rose-600 text-xs hover:underline">Delete</button>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </main>
</div>

<div id="providerModal" class="fixed inset-0 bg-slate-900/40 hidden items-center justify-center p-6 z-50">
  <div class="bg-white rounded-xl shadow-lg w-full max-w-lg p-6">
    <h2 id="providerModalTitle" class="text-lg font-semibold mb-4">Add provider</h2>
    <form id="providerForm" class="space-y-3 text-sm">
      <input type="hidden" name="id" />
      <div>
        <label class="block text-xs text-slate-600 mb-1">Name *</label>
        <input name="name" required class="w-full border border-slate-300 rounded-md px-3 py-2" placeholder="e.g. OpenAI main" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-slate-600 mb-1">Type *</label>
          <select name="type" class="w-full border border-slate-300 rounded-md px-3 py-2">
            <% types.forEach(t => { %>
              <option value="<%= t %>"><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs text-slate-600 mb-1">Auth type</label>
          <select name="auth_type" class="w-full border border-slate-300 rounded-md px-3 py-2">
            <option value="bearer">bearer</option>
            <option value="oauth">oauth</option>
            <option value="none">none</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs text-slate-600 mb-1">Base URL *</label>
        <input name="base_url" required class="w-full border border-slate-300 rounded-md px-3 py-2 font-mono text-xs" placeholder="https://api.openai.com/v1" />
      </div>
      <div>
        <label class="block text-xs text-slate-600 mb-1">API key (upstream)</label>
        <input name="api_key" class="w-full border border-slate-300 rounded-md px-3 py-2 font-mono text-xs" placeholder="sk-..." />
        <p class="text-xs text-slate-400 mt-1">Leave blank to keep existing value when editing.</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 mb-1">Config JSON</label>
        <textarea name="config_json" rows="3" class="w-full border border-slate-300 rounded-md px-3 py-2 font-mono text-xs" placeholder='{"headers": {"X-Custom": "val"}}'>{}</textarea>
      </div>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="enabled" /> Enabled
      </label>
      <div id="providerFormError" class="text-sm text-rose-600 hidden"></div>
      <div class="flex justify-end gap-2 pt-2">
        <button type="button" onclick="closeProviderModal()" class="px-3 py-2 rounded-md text-slate-600 hover:bg-slate-100 text-sm">Cancel</button>
        <button class="bg-brand-500 hover:bg-brand-600 text-white px-4 py-2 rounded-md text-sm">Save</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/providers.js"></script>
</body>
</html>
