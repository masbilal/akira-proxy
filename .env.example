# Server
PORT=3000
NODE_ENV=development

# Admin login (dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Session
SESSION_SECRET=please-change-this-to-a-long-random-string
SESSION_TTL_SEC=604800
SESSION_PRUNE_INTERVAL_MS=3600000
# Set to 1 only when the app is served behind HTTPS and you want secure cookies.
SESSION_SECURE_COOKIE=0

# Database
DB_PATH=./data/dapuranmu.db

# Auto MySQL/MariaDB backup (runs every BACKUP_INTERVAL_MS, default 30 min).
# SQLite stays the source of truth; MySQL is a hot standby for disaster recovery.
# Set BACKUP_ENABLED=0 to disable.
BACKUP_ENABLED=1
BACKUP_INTERVAL_MS=1800000
BACKUP_MYSQL_HOST=127.0.0.1
BACKUP_MYSQL_PORT=3306
BACKUP_MYSQL_USER=root
BACKUP_MYSQL_PASSWORD=
BACKUP_MYSQL_DATABASE=dapuranmu

# ----------------------------------------------------------------------------
# Multi-instance sync (local <-> VPS)
# ----------------------------------------------------------------------------
# Mode for THIS instance:
#   disabled  - single-instance, no sync (default).
#   hub       - serves /api/sync/* so peers can replicate against it.
#               Use on the VPS / always-on instance.
#   peer      - pushes/pulls changes against SYNC_HUB_URL on a timer.
#               Use on local dev machines.
SYNC_MODE=disabled

# Stable identifier for this instance. Used to detect echoes and resolve
# tie-breaks. If left empty, a random `node-xxxx` is generated and persisted
# in sync_config so every restart reuses it. Set this explicitly when you
# want a human-readable name like `vps-prod` or `laptop-dewa`.
SYNC_NODE_ID=

# Peer-only: where the hub lives. Example:
#   SYNC_HUB_URL=https://router.example.com
SYNC_HUB_URL=

# Shared secret used for /api/sync/* bearer auth on BOTH sides. Generate
# something long, e.g. `openssl rand -hex 32`. Required on hub and peer.
SYNC_SECRET=

# How often (ms) the peer pushes/pulls. Default 15s.
SYNC_INTERVAL_MS=15000
# Max changes per push/pull batch.
SYNC_PUSH_LIMIT=500
SYNC_PULL_LIMIT=500
# HTTP request timeout (ms) for sync calls.
SYNC_REQUEST_TIMEOUT_MS=20000

# Optional: Kiro runtime mode
# `auto` prefers direct HTTP, and switches to cli only when KIRO_API_KEY is set.
KIRO_API_KEY=
KIRO_CLI_PATH=
KIRO_RUNTIME=auto
KIRO_GENERATE_URL=
KIRO_USAGE_BASE=
KIRO_TRUST_TOOLS=
ACCOUNT_ERROR_COOLDOWN_SEC=300
ACCOUNT_SELECTION_MODE=smart
ACCOUNT_MIN_REUSE_GAP_SEC=45
